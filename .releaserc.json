{
    "branches": [
        "main",
        "master"
    ],
    "plugins": [
        "@semantic-release/commit-analyzer",
        "@semantic-release/release-notes-generator",
        "@semantic-release/changelog",
        [
            "@semantic-release/exec",
            {
                "prepareCmd": "sed -i 's/version=\".*\"/version=\"${nextRelease.version}\"/' setup.py && sed -i 's/__version__ = \".*\"/__version__ = \"${nextRelease.version}\"/' luminalog/__init__.py",
                "publishCmd": "python3 -m build && python3 -m twine upload dist/*"
            }
        ],
        [
            "@semantic-release/git",
            {
                "assets": [
                    "setup.py",
                    "luminalog/__init__.py",
                    "CHANGELOG.md"
                ],
                "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
            }
        ],
        "@semantic-release/github"
    ]
}